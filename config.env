# ══════════════════════════════════════════════
# LocoBase Configuration
#
# Machine identity (MACHINE_NAME, PROMPT_EMOJI) is set by the
# install.sh menu and saved in .machine — do not set here.
#
# SETUP_USER is auto-detected from the account running sudo.
# Override below only if you need a different target user.
# ══════════════════════════════════════════════

# --- User (auto-detected, override if needed) ---
# SETUP_USER="michael"

# --- Prompt ---
PROMPT_COLOR="1;36m"                # Cyan — color for machine name and path

# --- Plymouth ---
PLYMOUTH_ENABLE=true                # Install plymouth boot splash
PLYMOUTH_FONT="future"             # figlet/toilet font for splash PNG
PLYMOUTH_FG_COLOR="cyan"           # Text color for splash PNG

# --- MOTD ---
MOTD_ENABLE=true                   # Install custom MOTD

# --- NVIDIA ---
NVIDIA_ENABLE=true                  # Install NVIDIA drivers
NVIDIA_DRIVER_VERSION="535"         # Driver version to install

# --- AI Stack ---
CUDA_ENABLE=true                    # Install CUDA toolkit
CUDA_VERSION="12-4"                 # CUDA version (supports compute 5.0+ = GTX 950 through RTX 4050)
OLLAMA_ENABLE=true                  # Install Ollama inference engine
DOCKER_ENABLE=true                  # Install Docker + NVIDIA Container Toolkit
NODEJS_ENABLE=true                  # Install Node.js LTS (for Astro docs sites)
NODEJS_VERSION="22"                 # Node.js major version
HF_CLI_ENABLE=true                  # Install HuggingFace CLI (requires Python)

# --- Autologin ---
AUTOLOGIN_ENABLE=true               # Auto-login on tty1
AUTOLOGIN_TTY="tty1"                # Which TTY to auto-login on

# --- Dashboard (tmux on TTY) ---
DASHBOARD_ENABLE=true               # Launch tmux dashboard on autologin TTY
DASHBOARD_LAYOUT="tiled"            # tiled, even-horizontal, even-vertical, main-horizontal, main-vertical
DASHBOARD_ROTATE_INTERVAL=300       # Default rotation interval in seconds (5 min)

# Panes — set to "" or comment out to disable
# Use | to separate multiple commands that rotate within the same pane
# e.g. DASHBOARD_PANE_2="cmatrix -C cyan | pipes.sh | cbonsai --live --infinite"
# Per-pane interval override: DASHBOARD_PANE_N_INTERVAL=60
DASHBOARD_PANE_1="htop"
DASHBOARD_PANE_2="cmatrix -C cyan"
DASHBOARD_PANE_3="cbonsai --live --infinite"
DASHBOARD_PANE_4="pipes.sh"
DASHBOARD_PANE_5=""
DASHBOARD_PANE_6=""
DASHBOARD_PANE_7=""
DASHBOARD_PANE_8=""
# Other options: btop, asciiquarium, "tty-clock -c -C 6", nmon, "neofetch --loop", "watch -n2 -c nvidia-smi"

# --- Hardening ---
UFW_ENABLE=true                     # Enable UFW firewall
FAIL2BAN_ENABLE=true                # Enable fail2ban

# --- Packages ---
# Extra apt packages to install (space-separated)
EXTRA_PACKAGES=""

# ── Load machine identity (auto-set by install.sh menu) ──
_MACHINE_SETUP_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
if [[ -f "$_MACHINE_SETUP_DIR/.machine" ]]; then
    source "$_MACHINE_SETUP_DIR/.machine"
fi
unset _MACHINE_SETUP_DIR

# ── Auto-detect user if not set ──
if [[ -z "$SETUP_USER" ]]; then
    SETUP_USER="${SUDO_USER:-$(logname 2>/dev/null || echo "$USER")}"
fi
